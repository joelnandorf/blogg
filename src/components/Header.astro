---
const navLinks = [
  { href: '/', label: 'Inlägg' },
  { href: '/om', label: 'Om' },
  { href: '/rss.xml', label: 'RSS' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-border bg-background/90 backdrop-blur-sm sticky top-0 z-40">
  <div class="app-layout">
    <div class="flex items-center justify-between h-14">
      <a
        href="/"
        class="font-lipi-sans font-bold text-base tracking-tight text-foreground hover:text-foreground no-underline"
        aria-label="Shift+Build — hem"
      >
        Shift<span class="text-primary">+</span>Build
      </a>

      <div class="flex items-center gap-1">
        <nav class="flex items-center gap-0.5" aria-label="Huvudnavigation">
          {navLinks.map(link => (
            <a
              href={link.href}
              aria-current={currentPath === link.href ? 'page' : undefined}
              class="nav-underline font-lipi-sans text-sm text-muted-foreground hover:text-foreground px-3 py-1.5 rounded transition-colors aria-[current=page]:text-foreground"
            >
              {link.label}
            </a>
          ))}
        </nav>

        <button
          id="theme-toggle"
          class="theme-toggle ml-2"
          aria-label="Växla tema"
          title="Växla mörkt/ljust läge"
        >
          <span class="dark-icon hidden">☀️</span>
          <span class="light-icon">🌙</span>
        </button>
      </div>
    </div>
  </div>
</header>

<script>
  function initThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    const root = document.documentElement;
    const darkIcon = btn.querySelector('.dark-icon') as HTMLElement | null;
    const lightIcon = btn.querySelector('.light-icon') as HTMLElement | null;

    function updateIcons() {
      const isDark = root.getAttribute('data-theme') === 'dark';
      if (darkIcon) darkIcon.classList.toggle('hidden', !isDark);
      if (lightIcon) lightIcon.classList.toggle('hidden', isDark);
    }

    updateIcons();

    btn.addEventListener('click', () => {
      const isDark = root.getAttribute('data-theme') === 'dark';
      const next = isDark ? 'light' : 'dark';
      root.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      updateIcons();
    });
  }

  initThemeToggle();
  document.addEventListener('astro:after-swap', initThemeToggle);
</script>
