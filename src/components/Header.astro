---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const navLinks = [
  { href: base || '/', label: 'Inlägg' },
  { href: `${base}/amnen`, label: 'Ämnen' },
  { href: `${base}/om`, label: 'Om' },
  { href: `${base}/rss.xml`, label: 'RSS' },
];

const homeHref = base || '/';
const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-40 bg-background/95 backdrop-blur-sm border-b border-outline-variant/40"
>
  <div class="app-layout flex items-center justify-between h-16 md:h-20 gap-4">
    <a
      href={base || '/'}
      class="font-display text-xl md:text-2xl text-ink tracking-tight no-underline hover:text-accent transition-colors"
      aria-label="Shift+Build — hem"
    >
      Shift<span class="text-accent">+</span>Build
    </a>

    <div class="flex items-center gap-4 md:gap-6">
      <nav
        class="flex items-center gap-6 md:gap-8 text-sm"
        aria-label="Huvudnavigation"
      >
        {
          navLinks.map((link) => {
            const isActive =
              currentPath === link.href ||
              (link.href !== homeHref &&
                currentPath.startsWith(`${link.href}/`));
            return (
              <a
                href={link.href}
                aria-current={isActive ? 'page' : undefined}
                class={`pb-1 border-b no-underline transition-colors duration-300 ${
                  isActive
                    ? 'text-ink border-ink'
                    : 'text-ink-muted border-transparent hover:text-ink hover:border-outline-variant'
                }`}
              >
                {link.label}
              </a>
            );
          })
        }
      </nav>

      <button
        id="theme-toggle"
        type="button"
        aria-label="Växla mellan ljust och mörkt läge"
        class="shrink-0 text-ink-muted hover:text-ink transition-colors duration-300"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="h-5 w-5 dark:hidden"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"
          ></path>
        </svg>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="hidden h-5 w-5 dark:block"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"
          ></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  const themeToggle = document.getElementById('theme-toggle');
  themeToggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>
